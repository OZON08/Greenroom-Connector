{
  "realm": "greenlight",
  "enabled": true,
  "displayName": "Greenlight (dev)",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "rememberMe": true,
  "verifyEmail": false,
  "sslRequired": "none",
  "accessTokenLifespan": 600,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "clients": [
    {
      "clientId": "greenlight",
      "name": "Greenlight Outlook dev client",
      "enabled": true,
      "publicClient": false,
      "protocol": "openid-connect",
      "secret": "greenlight-dev-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:3000/*"
      ],
      "webOrigins": [
        "http://localhost:3000"
      ],
      "attributes": {
        "post.logout.redirect.uris": "+",
        "pkce.code.challenge.method": ""
      },
      "defaultClientScopes": [
        "web-origins",
        "profile",
        "roles",
        "email"
      ]
    }
  ],
  "users": [
    {
      "username": "test",
      "email": "test@example.com",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Test",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "test123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "default-roles-greenlight"
      ]
    },
    {
      "username": "alice",
      "email": "alice@example.com",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Alice",
      "lastName": "Example",
      "credentials": [
        {
          "type": "password",
          "value": "alice123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "default-roles-greenlight"
      ]
    }
  ]
}
