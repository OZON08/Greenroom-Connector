<?xml version="1.0" encoding="UTF-8"?>
<?include Variables.generated.wxi ?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <!-- Name / Manufacturer / Version / Description come from
       /Directory.Build.props via the generated Variables.generated.wxi. -->
  <Package Name="$(var.ProductName)"
           Manufacturer="$(var.PublisherName)"
           Version="$(var.Version)"
           UpgradeCode="A1B2C3D4-9000-4000-8000-000000000001"
           Scope="perMachine"
           Compressed="yes">

    <SummaryInformation Description="$(var.Description)" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <!-- Public properties exposed for silent install:
           msiexec /i GreenroomConnector.msi /qn
             GREENLIGHTURL=https://bbb.example.com
             LANGUAGE=auto
             LOCATIONTEXT="BigBlueButton-Konferenz"
             SHOWDIALIN=true
             DIALINNUMBER="+49 30 1234 5678"
             DEBUGLOGGING=false
    -->
    <!-- Each property has a RegistrySearch so Modify/Repair pre-fills the wizard
         from HKLM. AppSearch only overwrites when the property hasn't been set on
         the command line, so silent installs (msiexec /qn ...) keep their values. -->
    <Property Id="GREENLIGHTURL" Value="https://" Secure="yes">
      <RegistrySearch Id="SrcGreenlightUrl" Root="HKLM" Key="SOFTWARE\GreenroomConnector" Name="GreenlightUrl" Type="raw" />
    </Property>
    <Property Id="LANGUAGE" Value="auto" Secure="yes">
      <RegistrySearch Id="SrcLanguage" Root="HKLM" Key="SOFTWARE\GreenroomConnector" Name="Language" Type="raw" />
    </Property>
    <!-- Optional. Written into the appointment Location field when empty.
         Supports the placeholder {room} which is replaced with the room name. -->
    <Property Id="LOCATIONTEXT" Secure="yes">
      <RegistrySearch Id="SrcLocationText" Root="HKLM" Key="SOFTWARE\GreenroomConnector" Name="LocationText" Type="raw" />
    </Property>
    <!-- Toggle ("true"/"false") for the localized dial-in block defined in
         Strings.Meeting_DialIn. The wrapping text lives in the resx; this
         flag plus DIALINNUMBER below control content. Default: false. -->
    <Property Id="SHOWDIALIN" Value="false" Secure="yes">
      <RegistrySearch Id="SrcShowDialIn" Root="HKLM" Key="SOFTWARE\GreenroomConnector" Name="ShowDialIn" Type="raw" />
    </Property>
    <!-- Deployment-specific dial-in phone number, substituted into the
         {number} placeholder of Strings.Meeting_DialIn. -->
    <Property Id="DIALINNUMBER" Secure="yes">
      <RegistrySearch Id="SrcDialInNumber" Root="HKLM" Key="SOFTWARE\GreenroomConnector" Name="DialInNumber" Type="raw" />
    </Property>
    <!-- Toggle ("true"/"false") for the verbose file logger under
         %LocalAppData%\GreenroomConnector\debug.log. Off by default; the log
         records full HTTP response bodies and exception stacks, so it is a
         privacy + disk-growth concern when always on. -->
    <Property Id="DEBUGLOGGING" Value="false" Secure="yes">
      <RegistrySearch Id="SrcDebugLogging" Root="HKLM" Key="SOFTWARE\GreenroomConnector" Name="DebugLogging" Type="raw" />
    </Property>

    <!-- Require GREENLIGHTURL before non-interactive installs. Full UI installs collect it in GrcServerDlg. -->
    <Launch Condition="Installed OR UILevel = 5 OR (GREENLIGHTURL AND GREENLIGHTURL &lt;&gt; &quot;https://&quot; AND GREENLIGHTURL &lt;&gt; &quot;http://&quot;)"
            Message="GREENLIGHTURL property is required. Example: msiexec /i GreenroomConnector.msi /qn GREENLIGHTURL=https://bbb.example.com" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Greenroom Connector">
        <Directory Id="AddInDeFolder" Name="de" />
        <Directory Id="AddInRuntimesFolder" Name="runtimes">
          <Directory Id="AddInWinX64Folder" Name="win-x64">
            <Directory Id="AddInWinX64NativeFolder" Name="native" />
          </Directory>
        </Directory>
      </Directory>
    </StandardDirectory>

    <Feature Id="Main" Title="Greenroom Connector" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentGroupRef Id="RegistryComponents" />
      <ComponentGroupRef Id="OutlookAddinComponents" />
    </Feature>

    <!-- Custom wizard UI defined in UI.wxs. -->
    <UIRef Id="GrcWizardUI" />

    <!-- Branding: license shown in LicenseAgreementDlg, banner & dialog bitmaps for the wizard. -->
    <WixVariable Id="WixUILicenseRtf" Value="assets\license.rtf" />
    <WixVariable Id="WixUIBannerBmp"  Value="assets\BannerBitmap.bmp" />
    <WixVariable Id="WixUIDialogBmp"  Value="assets\DialogBitmap.bmp" />

    <!-- Add/Remove Programs icon. -->
    <Icon Id="AppIcon.ico" SourceFile="assets\AppIcon.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon.ico" />

  </Package>

  <!-- Add-in binaries: file harvesting is done via ProjectReference output groups.
       The $(var.GreenroomConnector.TargetDir) variable is provided by the wixproj
       ProjectReference; here we enumerate the VSTO artifacts explicitly to stay robust. -->
  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Component Id="AddInAssembly" Guid="A1B2C3D4-A001-4000-8000-000000000001">
        <File Id="AddInDll"
              Source="$(var.GreenroomConnector.TargetPath)"
              KeyPath="yes" />
      </Component>
      <Component Id="AddInConfig" Guid="A1B2C3D4-A001-4000-8000-000000000002">
        <File Id="AddInConfigFile"
              Source="$(var.GreenroomConnector.TargetDir)GreenroomConnector.dll.config"
              KeyPath="yes" />
      </Component>
      <Component Id="AddInVstoManifest" Guid="A1B2C3D4-A001-4000-8000-000000000003">
        <File Id="AddInVstoFile"
              Source="$(var.GreenroomConnector.TargetDir)GreenroomConnector.vsto"
              KeyPath="yes" />
      </Component>
      <Component Id="AddInDllManifest" Guid="A1B2C3D4-A001-4000-8000-000000000004">
        <File Id="AddInDllManifestFile"
              Source="$(var.GreenroomConnector.TargetDir)GreenroomConnector.dll.manifest"
              KeyPath="yes" />
      </Component>
      <Component Id="AddInVstoUtilities" Guid="A1B2C3D4-A001-4000-8000-000000000005">
        <File Id="MicrosoftOfficeToolsCommonUtilities"
              Source="$(var.GreenroomConnector.TargetDir)Microsoft.Office.Tools.Common.v4.0.Utilities.dll"
              KeyPath="yes" />
        <File Id="MicrosoftOfficeToolsOutlookUtilities"
              Source="$(var.GreenroomConnector.TargetDir)Microsoft.Office.Tools.Outlook.v4.0.Utilities.dll" />
      </Component>
      <Component Id="AddInPackageDependencies" Guid="A1B2C3D4-A001-4000-8000-000000000006">
        <File Id="NewtonsoftJson"
              Source="$(var.GreenroomConnector.TargetDir)Newtonsoft.Json.dll"
              KeyPath="yes" />
        <File Id="MicrosoftWebWebView2Core"
              Source="$(var.GreenroomConnector.TargetDir)Microsoft.Web.WebView2.Core.dll" />
        <File Id="MicrosoftWebWebView2WinForms"
              Source="$(var.GreenroomConnector.TargetDir)Microsoft.Web.WebView2.WinForms.dll" />
        <File Id="MicrosoftWebWebView2Wpf"
              Source="$(var.GreenroomConnector.TargetDir)Microsoft.Web.WebView2.Wpf.dll" />
      </Component>
      <Component Id="AddInDeSatelliteAssembly" Directory="AddInDeFolder" Guid="A1B2C3D4-A001-4000-8000-000000000007">
        <File Id="AddInDeResources"
              Source="$(var.GreenroomConnector.TargetDir)de\GreenroomConnector.resources.dll"
              KeyPath="yes" />
      </Component>
      <Component Id="AddInWebView2LoaderX64" Directory="AddInWinX64NativeFolder" Guid="A1B2C3D4-A001-4000-8000-000000000008">
        <File Id="WebView2LoaderX64"
              Source="$(var.GreenroomConnector.TargetDir)runtimes\win-x64\native\WebView2Loader.dll"
              KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

</Wix>
