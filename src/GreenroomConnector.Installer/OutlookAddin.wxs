<?xml version="1.0" encoding="UTF-8"?>
<?include Variables.generated.wxi ?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <!-- VSTO add-in registration (per-machine, HKLM).
       The Manifest value tells Outlook to load the .vsto deployment manifest with
       the |vstolocal suffix, meaning it is not cached by ClickOnce but loaded from
       the installation directory. -->
  <Fragment>
    <ComponentGroup Id="OutlookAddinComponents" Directory="INSTALLFOLDER">
      <Component Id="OutlookAddinRegistration" Guid="A1B2C3D4-C001-4000-8000-000000000001">
        <RegistryKey Root="HKLM"
                     Key="SOFTWARE\Microsoft\Office\Outlook\Addins\GreenroomConnector">
          <!-- Surfaced in Outlook → File → Options → Add-ins → COM Add-ins.
               Use the short form: Outlook truncates / blanks the row when
               Description gets past ~256 chars. -->
          <RegistryValue Type="string" Name="Description"
                         Value="$(var.ShortDescription)" />
          <RegistryValue Type="string" Name="FriendlyName"
                         Value="$(var.ProductName)" />
          <RegistryValue Type="integer" Name="LoadBehavior" Value="3" />
          <RegistryValue Type="string" Name="Manifest"
                         Value="file:///[INSTALLFOLDER]GreenroomConnector.vsto|vstolocal"
                         KeyPath="yes" />
        </RegistryKey>
      </Component>
    </ComponentGroup>
  </Fragment>

</Wix>
